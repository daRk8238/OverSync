{
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @oversync/sdk build && pnpm --filter @oversync/frontend build && mkdir -p frontend/dist && cp -r dist/. frontend/dist/",
  "outputDirectory": "dist",
  "installCommand": "npm install -g pnpm@latest",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
